# Supabase (required for admin + live products)
# Project URL from Supabase → Settings → API → Project URL (must start with https://)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
# anon public key from the same page (starts with eyJ...)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Optional
GOOGLE_PLACES_API_KEY=
GOOGLE_PLACE_ID=
NEXT_PUBLIC_APP_URL=http://localhost:3000

# GitHub Pages static export (optional)
# GITHUB_PAGES=true
